# Copy to backend/.env and fill in. Nothing here is needed to START the app.
DATABASE_URL=sqlite:///./data/graphy.db
CHROMA_PATH=./data/chroma
UPLOAD_DIR=./data/uploads
EVIDENCE_DIR=./data/evidence

# LLM provider: gemini | ollama
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama alternate (only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Embeddings run locally (no key). Leave as-is.
EMBED_BACKEND=local

# Phase 2+: GitHub read-only Personal Access Token
GITHUB_TOKEN=
